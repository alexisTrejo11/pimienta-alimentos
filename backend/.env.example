# Copy to backend/.env. Compose loads this automatically from backend/.
#   docker compose up -d --build              # API only (cloud)
#   docker compose --profile local up --build # API + Postgres + Redis
# For local `mvn spring-boot:run` / IDE, DotenvEnvironmentPostProcessor loads the same file.

# --- PostgreSQL ---
POSTGRES_DB=pimienta_alimentos
POSTGRES_USER=pimienta_dba
POSTGRES_PASSWORD=pimienta_dba
POSTGRES_PORT=5431
# Host / IDE:
# POSTGRES_URL=jdbc:postgresql://localhost:5431/pimienta_alimentos
# Compose --profile local (in-network):
POSTGRES_URL=jdbc:postgresql://postgres:5432/pimienta_alimentos

# --- Redis ---
# Host / IDE: redis://localhost:6378
# Compose --profile local: redis://redis:6379
# Upstash (TLS): rediss://default:TOKEN@HOST:6379
REDIS_URL=redis://redis:6379

PIMIENTA_REDIS_KEY_PREFIX=pimienta-alimentos

# CORS — comma-separated SPA origins (no trailing slash)
PIMIENTA_CORS_ALLOWED_ORIGINS=http://localhost:4000,http://localhost:4001,http://localhost:3000,http://127.0.0.1:4000,http://127.0.0.1:4001,http://127.0.0.1:3000

# API
API_PORT=8080

# JWT — set a long random secret in production
PIMIENTA_SECURITY_JWT_SECRET=change-me-use-at-least-256-bits-for-hs256-secret-key-pimienta

JAVA_OPTS=

# AWS
AWS_REGION=us-east-1
AWS_S3_FOLDER=employees
AWS_S3_SOURCES_ROOT=pimienta/sources
AWS_S3_BUCKET_NAME=pimienta-employees
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
