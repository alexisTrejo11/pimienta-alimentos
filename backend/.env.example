# Copy to backend/.env (project root). Compose loads it when you run from backend/:
#   docker compose -f docker/docker-compose.local.yml ...
#   docker compose -f docker/docker-compose.cloud.yml ...
# For local `mvn spring-boot:run` / IDE, DotenvEnvironmentPostProcessor loads the same file.

# --- PostgreSQL ---
POSTGRES_DB=pimienta_alimentos
POSTGRES_USER=pimienta_dba
POSTGRES_PASSWORD=pimienta_dba
POSTGRES_PORT=5431
POSTGRES_URL=jdbc:postgresql://localhost:5431/pimienta_alimentos

# --- Redis (single URL; switch environment by changing this only) ---
# Local Compose published port (mvn / IDE on host):
# REDIS_URL=redis://localhost:6378
# Local Compose in-network (api container; default in docker-compose.local.yml):
# REDIS_URL=redis://redis:6379
# Upstash (TLS):
# REDIS_URL=rediss://default:YOUR_TOKEN@YOUR-ENDPOINT.upstash.io:6379
REDIS_URL=redis://localhost:6378

# Namespace for all keys on shared Redis instances (Upstash, ElastiCache, etc.)
PIMIENTA_REDIS_KEY_PREFIX=pimienta-alimentos

# API
API_PORT=8080

# JWT — set a long random secret in production
PIMIENTA_SECURITY_JWT_SECRET=change-me-use-at-least-256-bits-for-hs256-secret-key-pimienta

# Optional JVM flags, e.g. -Xmx512m
JAVA_OPTS=

# AWS
AWS_REGION=us-east-1
AWS_S3_FOLDER=employees
AWS_S3_SOURCES_ROOT=pimienta/sources
AWS_S3_BUCKET_NAME=pimienta-employees
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
