# Copy to .env next to docker-compose.yml and adjust (docker compose loads .env automatically).
# For local `mvn spring-boot:run` / IDE runs from this directory, DotenvEnvironmentPostProcessor
# loads the same .env into the Spring Environment (OS env vars still override).

# PostgreSQL
POSTGRES_DB=pimienta_alimentos
POSTGRES_USER=pimienta_dba
POSTGRES_PASSWORD=pimienta_dba
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# API
API_PORT=8080

# JWT — set a long random secret in production
PIMIENTA_SECURITY_JWT_SECRET=change-me-use-at-least-256-bits-for-hs256-secret-key-pimienta

# Optional JVM flags, e.g. -Xmx512m
JAVA_OPTS=

# AWS
AWS_REGION=us-east-1
AWS_S3_FOLDER=employees
AWS_S3_BUCKET_NAME=pimienta-employees
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
